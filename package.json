{
  "name": "@callowayisweird/supersaas",
  "version": "1.0.0",
  "description": "Modern, fully-typed TypeScript SDK for the SuperSaaS booking platform.",
  "keywords": [
    "supersaas",
    "booking",
    "scheduling",
    "appointments",
    "typescript",
    "sdk"
  ],
  "license": "MIT",
  "author": "CallowayIsWeird",
  "homepage": "https://github.com/CallowayIsWeird/supersaas-api#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CallowayIsWeird/supersaas-api.git"
  },
  "bugs": {
    "url": "https://github.com/CallowayIsWeird/supersaas-api/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build",
    "release": "npm run prepublishOnly && npm publish --access public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
